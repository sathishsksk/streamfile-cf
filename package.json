{
  "name": "file-to-link-bot",
  "version": "2.0.0",
  "description": "Telegram File-To-Link bot rewritten for Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "setup-kv": "wrangler kv:namespace create FILES_KV",
    "set-token": "wrangler secret put BOT_TOKEN",
    "set-channel": "wrangler secret put BIN_CHANNEL",
    "set-pass": "wrangler secret put MY_PASS",
    "set-owner": "wrangler secret put OWNER_ID",
    "logs": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
